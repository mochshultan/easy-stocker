{
  "name": "kaizen-stock-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Industrial stock data dashboard with CSV/XLSX import, image storage, and stock movement audit trail.",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"tsx watch server/index.ts\" \"vite --host 0.0.0.0\"",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.node.json && vite build",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "import:excel": "tsx server/scripts/import-file.ts Data_Barang_19.xlsx"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "multer": "^2.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest-axe": "^3.5.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
